<Application x:Class="Sakura.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Sakura.App.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Tokens.xaml"/>
                <ResourceDictionary Source="Resources/Typography.xaml"/>
                <ResourceDictionary Source="Resources/Controls/CaptionButton.xaml"/>
                <ResourceDictionary Source="Resources/Controls/Button.xaml"/>
                <ResourceDictionary Source="Resources/Controls/ToggleButton.xaml"/>
                <ResourceDictionary Source="Resources/Controls/TextBox.xaml"/>
                <ResourceDictionary Source="Resources/Controls/Slider.xaml"/>
                <ResourceDictionary Source="Resources/Controls/ComboBox.xaml"/>
                <ResourceDictionary Source="Resources/Controls/ScrollBar.xaml"/>
                <ResourceDictionary Source="Resources/Controls/ScrollViewer.xaml"/>
                <ResourceDictionary Source="Resources/Controls/ListBox.xaml"/>
                <ResourceDictionary Source="Resources/Controls/Card.xaml"/>
                <ResourceDictionary Source="Resources/Controls/NavItem.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:HexToColorConverter                 x:Key="HexToColorConverter"/>
            <conv:IntEqualConverter                   x:Key="IntEqualConverter"/>
            <conv:InverseBoolConverter                x:Key="InverseBoolConverter"/>
            <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
            <conv:StringSplitConverter                x:Key="StringSplitConverter"/>
            <conv:IntToVisibilityConverter            x:Key="IntToVisibilityConverter"/>
            <conv:IntToZeroVisibilityConverter        x:Key="IntToZeroVisibilityConverter"/>
            <conv:InverseBoolToVisibilityConverter    x:Key="InverseBoolToVisibilityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
