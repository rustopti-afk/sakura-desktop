<Page x:Class="Sakura.App.Views.Pages.ProfileEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:Sakura.App.Localization"
      Title="Profile Editor">

    <Page.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveProfileCommand}"/>
    </Page.InputBindings>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">

            <!-- header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding [Editor_Title], Source={x:Static loc:LocalizationService.Instance}}"
                               Style="{StaticResource Sakura.Text.Title}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding [Editor_Subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                               Style="{StaticResource Sakura.Text.Caption}"
                               Opacity="0.65"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Defaults"
                            Command="{Binding LoadDefaultsCommand}"
                            Style="{StaticResource Sakura.Button.Secondary}"
                            Padding="10,5" Margin="0,0,6,0"/>
                    <Button Content="Load Sakura Yoru"
                            Command="{Binding LoadFromSakuraYoruCommand}"
                            Style="{StaticResource Sakura.Button.Secondary}"
                            Padding="10,5" Margin="0,0,6,0"/>
                    <Button Content="Export…"
                            Command="{Binding ExportProfileCommand}"
                            Style="{StaticResource Sakura.Button.Secondary}"
                            Padding="10,5" Margin="0,0,6,0"/>
                    <Button Content="Save"
                            Command="{Binding SaveProfileCommand}"
                            Padding="14,5"/>
                </StackPanel>
            </Grid>

            <!-- ── Meta ──────────────────────────────────────────────────── -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{Binding [Editor_Section_Info], Source={x:Static loc:LocalizationService.Instance}}"
                               Style="{StaticResource Sakura.Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Author" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox  Grid.Row="1" Grid.Column="1" Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Description" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Top" Margin="0,4,0,8"/>
                        <TextBox  Grid.Row="2" Grid.Column="1" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="52" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Tags" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center"/>
                        <TextBox  Grid.Row="3" Grid.Column="1" Text="{Binding TagsRaw, UpdateSourceTrigger=PropertyChanged}" ToolTip="Comma-separated tags (dark, sakura, minimal…)"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Compositor ─────────────────────────────────────────────── -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Compositor / DWM"
                               Style="{StaticResource Sakura.Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Dark Mode" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <CheckBox  Grid.Row="0" Grid.Column="1" IsChecked="{Binding DarkMode}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Transparency" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,8"/>
                        <CheckBox  Grid.Row="0" Grid.Column="3" IsChecked="{Binding Transparency}" VerticalAlignment="Center" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Color Prevalence" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <CheckBox  Grid.Row="1" Grid.Column="1" IsChecked="{Binding ColorPrevalence}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Animations" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,8"/>
                        <CheckBox  Grid.Row="1" Grid.Column="3" IsChecked="{Binding AnimationsEnabled}" VerticalAlignment="Center" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Backdrop" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <ComboBox  Grid.Row="2" Grid.Column="1" ItemsSource="{Binding BackdropTypes}"
                                   SelectedIndex="{Binding BackdropType}" Margin="0,0,8,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Corners" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,8"/>
                        <ComboBox  Grid.Row="2" Grid.Column="3" ItemsSource="{Binding CornerPrefs}"
                                   SelectedIndex="{Binding CornerPref}" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Accent Color" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding AccentColor, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Border Color" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBox   Grid.Row="3" Grid.Column="3" Text="{Binding BorderColor, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Shell ──────────────────────────────────────────────────── -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Shell / Taskbar"
                               Style="{StaticResource Sakura.Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Taskbar" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1" ItemsSource="{Binding TaskbarAlignments}"
                                   SelectedIndex="{Binding TaskbarAlignment}" Margin="0,0,8,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Show Search" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,8"/>
                        <CheckBox  Grid.Row="0" Grid.Column="3" IsChecked="{Binding ShowSearch}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Show Widgets" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="1" Grid.Column="1" IsChecked="{Binding ShowWidgets}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Show Chat" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <CheckBox  Grid.Row="1" Grid.Column="3" IsChecked="{Binding ShowChat}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Terminal ───────────────────────────────────────────────── -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Terminal"
                               Style="{StaticResource Sakura.Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Color Scheme" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <CheckBox  Grid.Row="0" Grid.Column="1" IsChecked="{Binding ApplyColorScheme}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Oh My Posh" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,8"/>
                        <CheckBox  Grid.Row="0" Grid.Column="3" IsChecked="{Binding ApplyOhMyPosh}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Scheme Name" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding SchemeName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Font Face" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,8"/>
                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding FontFace, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Font Size" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center"/>
                        <Slider    Grid.Row="2" Grid.Column="1" Value="{Binding FontSize}" Minimum="8" Maximum="24" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Opacity %" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <Slider    Grid.Row="2" Grid.Column="3" Value="{Binding Opacity}" Minimum="20" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── WM ──────────────────────────────────────────────────────── -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Window Manager"
                               Style="{StaticResource Sakura.Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Engine" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1" ItemsSource="{Binding WmEngines}"
                                   SelectedItem="{Binding WmEngine}" Margin="0,0,8,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Layout" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,8"/>
                        <TextBox   Grid.Row="0" Grid.Column="3" Text="{Binding WmLayout, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Outer Gap" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <Slider    Grid.Row="1" Grid.Column="1" Value="{Binding WmOuterGap}" Minimum="0" Maximum="64" TickFrequency="2" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,8,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Inner Gap" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,8"/>
                        <Slider    Grid.Row="1" Grid.Column="3" Value="{Binding WmInnerGap}" Minimum="0" Maximum="64" TickFrequency="2" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Border" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center"/>
                        <CheckBox  Grid.Row="2" Grid.Column="1" IsChecked="{Binding WmBorderEnabled}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Active Color" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBox   Grid.Row="2" Grid.Column="3" Text="{Binding WmBorderActive, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Integrations flags ──────────────────────────────────────── -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Integrations"
                               Style="{StaticResource Sakura.Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <CheckBox IsChecked="{Binding ApplyRainmeter}" Margin="0,0,16,0"/>
                        <TextBlock Text="Rainmeter" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                        <CheckBox IsChecked="{Binding ApplyWindhawk}" Margin="0,0,16,0"/>
                        <TextBlock Text="Windhawk" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                        <CheckBox IsChecked="{Binding ApplyLively}" Margin="0,0,16,0"/>
                        <TextBlock Text="Lively Wallpaper" Style="{StaticResource Sakura.Text.Caption}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- status -->
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                        <Setter Property="Opacity" Value="0.7"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusSuccess}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Sakura.Brush.Accent}"/>
                                <Setter Property="Opacity" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</Page>
