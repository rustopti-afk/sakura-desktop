<UserControl x:Class="Sakura.App.Views.Pages.ProfilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Sakura.App.ViewModels"
      xmlns:loc="clr-namespace:Sakura.App.Localization">

    <UserControl.Resources>
        <!-- Tag chip style -->
        <Style x:Key="TagChip" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource Sakura.Brush.Surface}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Sakura.Brush.Accent}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="10"/>
            <Setter Property="Padding"          Value="8,2"/>
            <Setter Property="Margin"           Value="0,0,4,4"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left: profile list ─────────────────────────────────────────── -->
        <DockPanel Grid.Column="0" Margin="0,0,0,0"
                   AllowDrop="True"
                   DragOver="OnDragOver"
                   Drop="OnDrop">

            <!-- toolbar -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,12,12,8">
                <Button Content="{Binding [Profiles_Btn_LoadFile], Source={x:Static loc:LocalizationService.Instance}}"
                        Command="{Binding LoadFromFileCommand}"
                        Style="{StaticResource Sakura.Button.Secondary}"
                        Padding="10,5" Margin="0,0,6,0"/>
                <Button Content="{Binding [Profiles_Btn_ScanFolder], Source={x:Static loc:LocalizationService.Instance}}"
                        Command="{Binding ScanFolderCommand}"
                        Style="{StaticResource Sakura.Button.Secondary}"
                        Padding="10,5"/>
            </StackPanel>

            <!-- search -->
            <Grid DockPanel.Dock="Top" Margin="12,0,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Style="{StaticResource Sakura.TextBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Search profiles…"/>
                <Button Grid.Column="1" Content="✕"
                        FontSize="10" Padding="8,4" Margin="4,0,0,0"
                        Style="{StaticResource Sakura.Button.Secondary}"
                        Command="{Binding ClearSearchCommand}"
                        Visibility="{Binding SearchText,
                            Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
            </Grid>

            <!-- profile list -->
            <ListBox ItemsSource="{Binding ProfilesView}"
                     SelectedItem="{Binding SelectedProfile}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Margin"  Value="4,2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{StaticResource Sakura.Brush.Surface}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{StaticResource Sakura.Brush.Accent}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}"
                                       Style="{StaticResource Sakura.Text.Body}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Author}"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Opacity="0.7"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Drop hint (always visible at bottom of panel) -->
            <Border DockPanel.Dock="Bottom" Margin="8,4,8,8"
                    Padding="8,6" CornerRadius="6"
                    Background="{StaticResource Sakura.Brush.BgSunken}"
                    BorderBrush="{StaticResource Sakura.Brush.StrokeSubtle}"
                    BorderThickness="1">
                <TextBlock Text="Drop .json here"
                           FontSize="11"
                           Foreground="{StaticResource Sakura.Brush.FgMuted}"
                           HorizontalAlignment="Center"/>
            </Border>
        </DockPanel>

        <!-- splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{StaticResource Sakura.Brush.Surface}"/>

        <!-- ── Right: profile details + actions ──────────────────────────── -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,20">

                <!-- empty state -->
                <TextBlock Text="{Binding [Profiles_NoProfiles], Source={x:Static loc:LocalizationService.Instance}}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.5"
                           Margin="0,60,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Body}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedProfile}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- profile details (visible when something is selected) -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedProfile}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- name + author -->
                    <TextBlock Text="{Binding SelectedProfile.Name}"
                               Style="{StaticResource Sakura.Text.Title}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectedProfile.Author}"
                               Style="{StaticResource Sakura.Text.Caption}"
                               Opacity="0.7"
                               Margin="0,0,0,12"/>

                    <!-- description -->
                    <TextBlock Text="{Binding SelectedProfile.Description}"
                               Style="{StaticResource Sakura.Text.Body}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"
                               Opacity="0.85"/>

                    <!-- feature summary chips -->
                    <WrapPanel Margin="0,0,0,16">
                        <ItemsControl ItemsSource="{Binding SelectedProfile.FeatureSummary,
                            Converter={StaticResource StringSplitConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource TagChip}">
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource Sakura.Text.Caption}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>

                    <!-- metadata grid -->
                    <Border Background="{StaticResource Sakura.Brush.Surface}"
                            CornerRadius="8" Padding="16" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Min OS Build"
                                       Style="{StaticResource Sakura.Text.Caption}" Opacity="0.6"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding SelectedProfile.MinOsBuild}"
                                       Style="{StaticResource Sakura.Text.Caption}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Created"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Opacity="0.6" Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding SelectedProfile.CreatedUtc, StringFormat='{}{0:yyyy-MM-dd}'}"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Margin="0,6,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Tags"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Opacity="0.6" Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding SelectedProfile.Tags}"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Margin="0,6,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="File"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Opacity="0.6" Margin="0,6,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding SelectedProfile.FilePath}"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,6,0,0"/>
                        </Grid>
                    </Border>

                    <!-- action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Button Content="{Binding [Profiles_Btn_ApplySelected], Source={x:Static loc:LocalizationService.Instance}}"
                                Command="{Binding ApplySelectedCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource Sakura.Button.Primary}"
                                Padding="20,8" Margin="0,0,10,0"/>
                        <Button Content="{Binding [Btn_Export], Source={x:Static loc:LocalizationService.Instance}}"
                                Command="{Binding ExportSelectedCommand}"
                                Style="{StaticResource Sakura.Button.Secondary}"
                                Padding="14,8" Margin="0,0,10,0"/>
                        <Button Content="{Binding [Btn_Delete], Source={x:Static loc:LocalizationService.Instance}}"
                                Command="{Binding RemoveSelectedCommand}"
                                Style="{StaticResource Sakura.Button.Secondary}"
                                Padding="14,8"/>
                    </StackPanel>

                    <!-- progress -->
                    <ProgressBar Value="{Binding ApplyProgress}"
                                 Minimum="0" Maximum="100"
                                 Height="4" Margin="0,0,0,8"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- status -->
                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               Visibility="{Binding StatusMessage,
                                   Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ApplySuccess}" Value="True">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource Sakura.Brush.Accent}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
