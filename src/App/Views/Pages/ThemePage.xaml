<UserControl x:Class="Sakura.App.Views.Pages.ThemePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24" MaxWidth="680">

            <TextBlock Text="Theme Engine"
                       Style="{StaticResource Sakura.Text.Title}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Apply custom .msstyles themes via SecureUxTheme patcher"
                       Style="{StaticResource Sakura.Text.Caption}"
                       Opacity="0.65" Margin="0,0,0,24"/>

            <!-- SecureUxTheme status -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="SecureUxTheme"
                                       Style="{StaticResource Sakura.Text.Body}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SecureUxStatus}"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Opacity="0.7"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Refresh"
                                    Command="{Binding RefreshStatusCommand}"
                                    Style="{StaticResource Sakura.Button.Secondary}"
                                    Padding="10,5" Margin="0,0,8,0"/>
                            <Button Content="Install"
                                    Command="{Binding InstallSecureUxThemeCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                    Style="{StaticResource Sakura.Button.Secondary}"
                                    Padding="10,5" Margin="0,0,8,0"/>
                            <Button Content="Remove"
                                    Command="{Binding UninstallSecureUxThemeCommand}"
                                    IsEnabled="{Binding SecureUxInstalled}"
                                    Style="{StaticResource Sakura.Button.Secondary}"
                                    Padding="10,5"/>
                        </StackPanel>
                    </Grid>

                    <!-- Install hint when not installed -->
                    <Border Background="{StaticResource Sakura.Brush.BgOverlay}"
                            CornerRadius="6" Padding="12,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SecureUxInstalled}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock TextWrapping="Wrap"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.8">
                            SecureUxTheme is required to load custom .msstyles themes on Windows 11.
                            Click Install to download and activate it automatically.
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- .msstyles picker -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Theme File"
                               Style="{StaticResource Sakura.Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Theme name"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ThemeName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Sakura.TextBox}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text=".msstyles path"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding MsstylesPath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Sakura.TextBox}"
                                 IsReadOnly="True" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="Browse..."
                                Command="{Binding BrowseMsstylesCommand}"
                                Style="{StaticResource Sakura.Button.Secondary}"
                                Padding="12,5"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Apply Theme"
                                Command="{Binding ApplyThemeCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource Sakura.Button.Primary}"
                                Padding="20,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <ProgressBar Minimum="0" Maximum="100" IsIndeterminate="True"
                         Height="4" Margin="0,0,0,8"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusSuccess}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Sakura.Brush.Accent}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</UserControl>
