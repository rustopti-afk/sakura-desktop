<UserControl x:Class="Sakura.App.Views.Pages.WmPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24" MaxWidth="680">

            <TextBlock Text="Window Manager"
                       Style="{StaticResource Sakura.Text.Title}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Configure and launch Komorebi or GlazeWM tiling window manager"
                       Style="{StaticResource Sakura.Text.Caption}"
                       Opacity="0.65" Margin="0,0,0,24"/>

            <!-- Engine selector -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Engine" Style="{StaticResource Sakura.Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Select engine"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding EngineOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding Engine}"
                                  Style="{StaticResource Sakura.ComboBox}"/>
                    </Grid>

                    <!-- Install hints -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Install Komorebi"
                                Command="{Binding InstallKomorebiCommand}"
                                Visibility="{Binding KomorebiInstalled, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                Style="{StaticResource Sakura.Button.Secondary}"
                                Padding="12,5" Margin="0,0,8,0"/>
                        <TextBlock Text="Komorebi ✓"
                                   Visibility="{Binding KomorebiInstalled, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Foreground="{StaticResource Sakura.Brush.Accent}"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Content="Install GlazeWM"
                                Command="{Binding InstallGlazeWmCommand}"
                                Visibility="{Binding GlazeWmInstalled, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                Style="{StaticResource Sakura.Button.Secondary}"
                                Padding="12,5" Margin="0,0,8,0"/>
                        <TextBlock Text="GlazeWM ✓"
                                   Visibility="{Binding GlazeWmInstalled, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Foreground="{StaticResource Sakura.Brush.Accent}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Layout + gaps -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Layout &amp; Gaps"
                               Style="{StaticResource Sakura.Text.Body}"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Layout"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  ItemsSource="{Binding LayoutOptions}"
                                  SelectedItem="{Binding Layout}"
                                  Style="{StaticResource Sakura.ComboBox}"
                                  Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Outer gap (px)"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <Slider Grid.Row="1" Grid.Column="1"
                                Value="{Binding OuterGap}"
                                Minimum="0" Maximum="40" TickFrequency="4"
                                IsSnapToTickEnabled="True"
                                Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Inner gap (px)"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <Slider Grid.Row="2" Grid.Column="1"
                                Value="{Binding InnerGap}"
                                Minimum="0" Maximum="40" TickFrequency="4"
                                IsSnapToTickEnabled="True"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Border -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Window Border"
                                   Style="{StaticResource Sakura.Text.Body}"
                                   FontWeight="SemiBold"/>
                        <ToggleButton Grid.Column="1"
                                      IsChecked="{Binding BorderEnabled}"
                                      Style="{StaticResource Sakura.ToggleButton}"/>
                    </Grid>

                    <Grid IsEnabled="{Binding BorderEnabled}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Width (px)"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <Slider Grid.Row="0" Grid.Column="1"
                                Value="{Binding BorderWidth}"
                                Minimum="1" Maximum="8" TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Active color"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding BorderActive, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Sakura.TextBox}"
                                 Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Inactive color"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding BorderInactive, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Sakura.TextBox}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                <Button Content="Deploy Config"
                        Command="{Binding DeployConfigCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource Sakura.Button.Secondary}"
                        Padding="16,8" Margin="0,0,8,0"/>
                <Button Content="Deploy &amp; Start"
                        Command="{Binding ApplyAndStartCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource Sakura.Button.Primary}"
                        Padding="16,8" Margin="0,0,8,0"/>
                <Button Content="Stop WM"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        Style="{StaticResource Sakura.Button.Secondary}"
                        Padding="16,8"/>
            </StackPanel>

            <ProgressBar Minimum="0" Maximum="100" IsIndeterminate="True"
                         Height="4" Margin="0,0,0,8"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusSuccess}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Sakura.Brush.Accent}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</UserControl>
