<Page x:Class="Sakura.App.Views.Pages.IntegrationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:Sakura.App.Localization"
      Title="Integrations">

    <Page.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </Page.InputBindings>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">

            <!-- header -->
            <TextBlock Text="{Binding [Integrations_Title], Source={x:Static loc:LocalizationService.Instance}}"
                       Style="{StaticResource Sakura.Text.Title}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding [Integrations_Subtitle], Source={x:Static loc:LocalizationService.Instance}}"
                       Style="{StaticResource Sakura.Text.Caption}"
                       Opacity="0.65"
                       Margin="0,0,0,20"/>

            <!-- ── Rainmeter ──────────────────────────────────────────────── -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <!-- title row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Rainmeter"
                                       Style="{StaticResource Sakura.Text.Body}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding RainmeterStatus}"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Opacity="0.65"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Refresh All"
                                    Command="{Binding RainmeterRefreshCommand}"
                                    Style="{StaticResource Sakura.Button.Secondary}"
                                    IsEnabled="{Binding RainmeterInstalled}"
                                    Padding="10,4" Margin="0,0,6,0"/>
                            <Button Content="Install"
                                    Command="{Binding InstallRainmeterCommand}"
                                    Padding="10,4">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource Sakura.Button.Secondary}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RainmeterInstalled}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- skins -->
                    <TextBlock Text="Installed skins"
                               Style="{StaticResource Sakura.Text.Caption}"
                               Opacity="0.6"
                               Margin="0,0,0,4"
                               Visibility="{Binding RainmeterInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding InstalledSkins}"
                                  Visibility="{Binding RainmeterInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Sakura.Brush.Accent}"
                                        CornerRadius="4" Padding="8,3" Margin="0,0,6,6">
                                    <TextBlock Text="{Binding}"
                                               Style="{StaticResource Sakura.Text.Caption}"
                                               FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- layouts -->
                    <TextBlock Text="Layouts"
                               Style="{StaticResource Sakura.Text.Caption}"
                               Opacity="0.6"
                               Margin="0,8,0,4"
                               Visibility="{Binding RainmeterInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding InstalledLayouts}"
                                  Visibility="{Binding RainmeterInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Sakura.Brush.Surface}"
                                        CornerRadius="4" Padding="8,3" Margin="0,0,6,6">
                                    <TextBlock Text="{Binding}"
                                               Style="{StaticResource Sakura.Text.Caption}"
                                               FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Not installed — profiles with rainmeter.apply=true will be skipped"
                               Opacity="0.5" FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RainmeterInstalled}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ── Windhawk ───────────────────────────────────────────────── -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Windhawk"
                                       Style="{StaticResource Sakura.Text.Body}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding WindhawkStatus}"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Opacity="0.65"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Install"
                                Command="{Binding InstallWindhawkCommand}"
                                Padding="10,4">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource Sakura.Button.Secondary}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WindhawkInstalled}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- mod list with toggle -->
                    <ItemsControl ItemsSource="{Binding InstalledMods}"
                                  Visibility="{Binding WindhawkInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Sakura.Brush.Surface}"
                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Id}"
                                                       Style="{StaticResource Sakura.Text.Caption}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Version}"
                                                       Style="{StaticResource Sakura.Text.Caption}"
                                                       Opacity="0.5" FontSize="10"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                                Margin="8,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#44888888"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                            <Setter Property="Background"
                                                                    Value="{StaticResource Sakura.Brush.Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                                                        <Setter Property="Text" Value="Disabled"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                <Setter Property="Text" Value="Enabled"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <Button Grid.Column="2" Content="Toggle"
                                                Command="{Binding DataContext.ToggleModCommand,
                                                    RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource Sakura.Button.Secondary}"
                                                Padding="8,3" FontSize="11"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Not installed — profiles with windhawk.apply=true will be skipped"
                               Opacity="0.5" FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WindhawkInstalled}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ── Lively ─────────────────────────────────────────────────── -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Lively Wallpaper"
                                       Style="{StaticResource Sakura.Text.Body}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding LivelyStatus}"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Opacity="0.65"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Close All"
                                    Command="{Binding LivelyCloseAllCommand}"
                                    IsEnabled="{Binding LivelyInstalled}"
                                    Style="{StaticResource Sakura.Button.Secondary}"
                                    Padding="10,4" Margin="0,0,6,0"/>
                            <Button Content="Install"
                                    Command="{Binding InstallLivelyCommand}"
                                    Padding="10,4">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource Sakura.Button.Secondary}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LivelyInstalled}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- active wallpapers -->
                    <TextBlock Text="Active wallpapers"
                               Style="{StaticResource Sakura.Text.Caption}"
                               Opacity="0.6" Margin="0,0,0,4"
                               Visibility="{Binding LivelyInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding ActiveWallpapers}"
                                  Visibility="{Binding LivelyInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Sakura.Brush.Surface}"
                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Display}"
                                                   Style="{StaticResource Sakura.Text.Caption}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding InfoPath}"
                                                   Style="{StaticResource Sakura.Text.Caption}"
                                                   Opacity="0.5" TextTrimming="CharacterEllipsis"
                                                   FontSize="10"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="No active wallpapers"
                               Opacity="0.4"
                               Visibility="{Binding LivelyInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveWallpapers.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="Not installed — profiles with lively.apply=true will be skipped"
                               Opacity="0.5" FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LivelyInstalled}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ── Icons ──────────────────────────────────────────────────── -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Icons &amp; Cursors"
                                       Style="{StaticResource Sakura.Text.Body}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Opacity="0.65">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                                        <Setter Property="Text" Value="No packs found"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IconPackCount}" Value="0">
                                                <Setter Property="Text" Value="No packs found"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Open Folder"
                                    Command="{Binding OpenIconsFolderCommand}"
                                    Style="{StaticResource Sakura.Button.Secondary}"
                                    Padding="10,4" Margin="0,0,6,0"/>
                            <Button Content="Restore Defaults"
                                    Command="{Binding RestoreDefaultIconsCommand}"
                                    Style="{StaticResource Sakura.Button.Secondary}"
                                    Padding="10,4"/>
                        </StackPanel>
                    </Grid>

                    <!-- icon packs -->
                    <TextBlock Text="Icon packs" Style="{StaticResource Sakura.Text.Caption}"
                               Opacity="0.6" Margin="0,0,0,4"
                               Visibility="{Binding IconPacks.Count, Converter={StaticResource IntToVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding IconPacks}"
                                  Visibility="{Binding IconPacks.Count, Converter={StaticResource IntToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Sakura.Brush.Surface}"
                                        CornerRadius="4" Padding="8,3" Margin="0,0,6,6">
                                    <TextBlock Text="{Binding}" Style="{StaticResource Sakura.Text.Caption}" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- cursor packs -->
                    <TextBlock Text="Cursor packs" Style="{StaticResource Sakura.Text.Caption}"
                               Opacity="0.6" Margin="0,8,0,4"
                               Visibility="{Binding CursorPacks.Count, Converter={StaticResource IntToVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding CursorPacks}"
                                  Visibility="{Binding CursorPacks.Count, Converter={StaticResource IntToVisibilityConverter}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Sakura.Brush.Surface}"
                                        CornerRadius="4" Padding="8,3" Margin="0,0,6,6">
                                    <TextBlock Text="{Binding}" Style="{StaticResource Sakura.Text.Caption}" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Drop icon packs (folders with .ico/.cur/.ani files) into the icons base dir"
                               Opacity="0.5" FontStyle="Italic"
                               Visibility="{Binding IconPackCount, Converter={StaticResource IntToZeroVisibilityConverter}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}"/>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding IconsBaseDir}" Style="{StaticResource Sakura.Text.Caption}"
                               Opacity="0.4" TextTrimming="CharacterEllipsis" FontSize="10"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Boot (HackBGRT) ────────────────────────────────────────── -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Boot Splash (HackBGRT)"
                                       Style="{StaticResource Sakura.Text.Body}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding HackBgrtStatus}"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Opacity="0.65"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Open Folder"
                                    Command="{Binding OpenHackBgrtFolderCommand}"
                                    IsEnabled="{Binding HackBgrtInstalled}"
                                    Style="{StaticResource Sakura.Button.Secondary}"
                                    Padding="10,4"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Boot splash is deployed when a profile has boot.hackBgrtEnabled=true and a valid splashPath"
                               Opacity="0.5" FontStyle="Italic"
                               Visibility="{Binding HackBgrtInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}"/>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="HackBGRT not found — install it to enable boot logo customisation"
                               Opacity="0.5" FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HackBgrtInstalled}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- global status -->
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                        <Setter Property="Opacity" Value="0.7"/>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</Page>
