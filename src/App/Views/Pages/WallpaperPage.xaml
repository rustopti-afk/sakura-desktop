<UserControl x:Class="Sakura.App.Views.Pages.WallpaperPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24" MaxWidth="680">

            <TextBlock Text="Wallpaper"
                       Style="{StaticResource Sakura.Text.Title}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Set a static image or animated Lively Wallpaper"
                       Style="{StaticResource Sakura.Text.Caption}"
                       Opacity="0.65" Margin="0,0,0,24"/>

            <!-- Static wallpaper -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Static Image"
                                       Style="{StaticResource Sakura.Text.Body}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="JPG / PNG / BMP / GIF applied to all monitors"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Opacity="0.65"/>
                        </StackPanel>
                        <RadioButton Grid.Column="1" IsChecked="{Binding UseLively, Converter={StaticResource InverseBoolConverter}}"
                                     VerticalAlignment="Center" Margin="0,0,4,0"/>
                    </Grid>

                    <Grid IsEnabled="{Binding UseLively, Converter={StaticResource InverseBoolConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Image path"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Sakura.TextBox}"
                                 IsReadOnly="True" Margin="0,0,8,8"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="Browse..."
                                Command="{Binding BrowseImageCommand}"
                                Style="{StaticResource Sakura.Button.Secondary}"
                                Padding="12,5" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Fit"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding FitOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Value"
                                  SelectedValue="{Binding Fit}"
                                  Style="{StaticResource Sakura.ComboBox}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Lively wallpaper -->
            <Border Style="{StaticResource Sakura.Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Lively Animated Wallpaper"
                                       Style="{StaticResource Sakura.Text.Body}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="MP4 / WebM / HTML / GIF via rocksdanister/Lively"
                                       Style="{StaticResource Sakura.Text.Caption}"
                                       Opacity="0.65"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton IsChecked="{Binding UseLively}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="Install Lively"
                                    Command="{Binding InstallLivelyCommand}"
                                    Visibility="{Binding LivelyInstalled, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    Style="{StaticResource Sakura.Button.Secondary}"
                                    Padding="10,5"/>
                        </StackPanel>
                    </Grid>

                    <Grid IsEnabled="{Binding UseLively}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Wallpaper file"
                                   Style="{StaticResource Sakura.Text.Caption}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding LivelyVideoPath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Sakura.TextBox}"
                                 IsReadOnly="True" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="Browse..."
                                Command="{Binding BrowseLivelyVideoCommand}"
                                Style="{StaticResource Sakura.Button.Secondary}"
                                Padding="12,5"/>
                    </Grid>

                    <Button Content="Stop Lively"
                            Command="{Binding StopLivelyCommand}"
                            IsEnabled="{Binding LivelyInstalled}"
                            Style="{StaticResource Sakura.Button.Secondary}"
                            HorizontalAlignment="Left"
                            Padding="14,6" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <Button Content="Apply Wallpaper"
                    Command="{Binding ApplyCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                    Style="{StaticResource Sakura.Button.Primary}"
                    HorizontalAlignment="Left"
                    Padding="20,8" Margin="0,4,0,12"/>

            <ProgressBar Minimum="0" Maximum="100" IsIndeterminate="True"
                         Height="4" Margin="0,0,0,8"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Sakura.Text.Caption}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusSuccess}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Sakura.Brush.Accent}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</UserControl>
