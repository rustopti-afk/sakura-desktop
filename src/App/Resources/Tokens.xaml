<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ── Color primitives ───────────────────────────────────────────────── -->
    <Color x:Key="Sakura.Color.BgBase">#FF0D0F14</Color>
    <Color x:Key="Sakura.Color.BgRaised">#FF141823</Color>
    <Color x:Key="Sakura.Color.BgOverlay">#FF1B2030</Color>
    <Color x:Key="Sakura.Color.BgSunken">#FF0A0C11</Color>
    <Color x:Key="Sakura.Color.StrokeSubtle">#FF1F2433</Color>
    <Color x:Key="Sakura.Color.StrokeStrong">#FF2A3045</Color>
    <Color x:Key="Sakura.Color.FgPrimary">#FFEDE6EE</Color>
    <Color x:Key="Sakura.Color.FgSecondary">#FFA8A0B2</Color>
    <Color x:Key="Sakura.Color.FgMuted">#FF6E687A</Color>
    <Color x:Key="Sakura.Color.AccentPink">#FFE8A0BF</Color>
    <Color x:Key="Sakura.Color.AccentPinkDeep">#FFC76F92</Color>
    <Color x:Key="Sakura.Color.AccentGold">#FFC9A84C</Color>
    <Color x:Key="Sakura.Color.AccentGoldDim">#FF8E7530</Color>
    <Color x:Key="Sakura.Color.StateOk">#FF9BD4A0</Color>
    <Color x:Key="Sakura.Color.StateWarn">#FFE8C26F</Color>
    <Color x:Key="Sakura.Color.StateErr">#FFE07A8E</Color>
    <Color x:Key="Sakura.Color.CloseHover">#FF3A1A24</Color>
    <Color x:Key="Sakura.Color.Transparent">#00000000</Color>

    <!-- ── Brushes ─────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Sakura.Brush.BgBase"         Color="{StaticResource Sakura.Color.BgBase}"/>
    <SolidColorBrush x:Key="Sakura.Brush.BgRaised"       Color="{StaticResource Sakura.Color.BgRaised}"/>
    <SolidColorBrush x:Key="Sakura.Brush.BgOverlay"      Color="{StaticResource Sakura.Color.BgOverlay}"/>
    <SolidColorBrush x:Key="Sakura.Brush.BgSunken"       Color="{StaticResource Sakura.Color.BgSunken}"/>
    <SolidColorBrush x:Key="Sakura.Brush.StrokeSubtle"   Color="{StaticResource Sakura.Color.StrokeSubtle}"/>
    <SolidColorBrush x:Key="Sakura.Brush.StrokeStrong"   Color="{StaticResource Sakura.Color.StrokeStrong}"/>
    <SolidColorBrush x:Key="Sakura.Brush.FgPrimary"      Color="{StaticResource Sakura.Color.FgPrimary}"/>
    <SolidColorBrush x:Key="Sakura.Brush.FgSecondary"    Color="{StaticResource Sakura.Color.FgSecondary}"/>
    <SolidColorBrush x:Key="Sakura.Brush.FgMuted"        Color="{StaticResource Sakura.Color.FgMuted}"/>
    <SolidColorBrush x:Key="Sakura.Brush.AccentPink"     Color="{StaticResource Sakura.Color.AccentPink}"/>
    <SolidColorBrush x:Key="Sakura.Brush.AccentPinkDeep" Color="{StaticResource Sakura.Color.AccentPinkDeep}"/>
    <SolidColorBrush x:Key="Sakura.Brush.AccentGold"     Color="{StaticResource Sakura.Color.AccentGold}"/>
    <SolidColorBrush x:Key="Sakura.Brush.AccentGoldDim"  Color="{StaticResource Sakura.Color.AccentGoldDim}"/>
    <SolidColorBrush x:Key="Sakura.Brush.StateOk"        Color="{StaticResource Sakura.Color.StateOk}"/>
    <SolidColorBrush x:Key="Sakura.Brush.StateWarn"      Color="{StaticResource Sakura.Color.StateWarn}"/>
    <SolidColorBrush x:Key="Sakura.Brush.StateErr"       Color="{StaticResource Sakura.Color.StateErr}"/>
    <SolidColorBrush x:Key="Sakura.Brush.CloseHover"     Color="{StaticResource Sakura.Color.CloseHover}"/>
    <SolidColorBrush x:Key="Sakura.Brush.Transparent"    Color="{StaticResource Sakura.Color.Transparent}"/>

    <!-- ── Shape tokens ───────────────────────────────────────────────────── -->
    <CornerRadius x:Key="Sakura.Radius.Card">12</CornerRadius>
    <CornerRadius x:Key="Sakura.Radius.Control">8</CornerRadius>
    <CornerRadius x:Key="Sakura.Radius.Pill">999</CornerRadius>

    <!-- ── Size tokens ────────────────────────────────────────────────────── -->
    <sys:Double x:Key="Sakura.Size.Sidebar">220</sys:Double>
    <sys:Double x:Key="Sakura.Size.Preview">300</sys:Double>
    <sys:Double x:Key="Sakura.Size.TitleBar">48</sys:Double>
    <sys:Double x:Key="Sakura.Size.StatusBar">28</sys:Double>
    <sys:Double x:Key="Sakura.Size.NavItem">44</sys:Double>
    <sys:Double x:Key="Sakura.Size.CardGap">16</sys:Double>

    <!-- ── Spacing ────────────────────────────────────────────────────────── -->
    <Thickness x:Key="Sakura.Pad.Card">20</Thickness>
    <Thickness x:Key="Sakura.Pad.Control">12,8</Thickness>
    <Thickness x:Key="Sakura.Pad.NavItem">16,0</Thickness>

    <!-- ── Animation ─────────────────────────────────────────────────────── -->
    <Duration x:Key="Sakura.Duration.Fast">0:0:0.120</Duration>
    <Duration x:Key="Sakura.Duration.Med">0:0:0.200</Duration>
    <CubicEase x:Key="Sakura.Easing" EasingMode="EaseOut"/>

    <!-- ── Effects ───────────────────────────────────────────────────────── -->
    <DropShadowEffect x:Key="Sakura.Shadow.Card"
                      BlurRadius="24" ShadowDepth="6" Direction="270"
                      Opacity="0.45" Color="#FF000000"/>
    <DropShadowEffect x:Key="Sakura.Shadow.Glow"
                      BlurRadius="16" ShadowDepth="0"
                      Opacity="0.55" Color="{StaticResource Sakura.Color.AccentPink}"/>

</ResourceDictionary>
