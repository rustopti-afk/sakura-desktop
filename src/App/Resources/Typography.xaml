<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="Sakura.Font.Ui">Noto Sans JP, M PLUS Rounded 1c, Segoe UI</FontFamily>
    <FontFamily x:Key="Sakura.Font.Mono">JetBrainsMono Nerd Font, Cascadia Mono, Consolas</FontFamily>

    <Style x:Key="Sakura.Text.Display" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Sakura.Font.Ui}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="Foreground" Value="{StaticResource Sakura.Brush.FgPrimary}"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="Sakura.Text.Title" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Sakura.Font.Ui}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Sakura.Brush.FgPrimary}"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="Sakura.Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Sakura.Font.Ui}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource Sakura.Brush.FgPrimary}"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="LineHeight" Value="20"/>
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="Sakura.Text.Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Sakura.Font.Ui}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource Sakura.Brush.FgSecondary}"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="Sakura.Text.Mono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Sakura.Font.Mono}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource Sakura.Brush.AccentGold}"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

</ResourceDictionary>
