<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:p="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">

    <Style x:Key="Sakura.Toggle" TargetType="p:ToggleButton">
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="p:ToggleButton">
                    <Border x:Name="Track" CornerRadius="999"
                            Background="{StaticResource Sakura.Brush.BgSunken}"
                            BorderBrush="{StaticResource Sakura.Brush.StrokeSubtle}"
                            BorderThickness="1">
                        <Ellipse x:Name="Knob" Width="18" Height="18"
                                 HorizontalAlignment="Left" Margin="2,0,0,0"
                                 Fill="{StaticResource Sakura.Brush.FgSecondary}">
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="KnobSlide"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobSlide"
                                                         Storyboard.TargetProperty="X"
                                                         To="20" Duration="{StaticResource Sakura.Duration.Med}">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="Knob"
                                                        Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                                        To="{StaticResource Sakura.Color.BgBase}"
                                                        Duration="{StaticResource Sakura.Duration.Med}"/>
                                        <ColorAnimation Storyboard.TargetName="Track"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource Sakura.Color.AccentPink}"
                                                        Duration="{StaticResource Sakura.Duration.Med}"/>
                                        <ColorAnimation Storyboard.TargetName="Track"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="{StaticResource Sakura.Color.AccentPink}"
                                                        Duration="{StaticResource Sakura.Duration.Med}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="KnobSlide"
                                                         Storyboard.TargetProperty="X"
                                                         To="0" Duration="{StaticResource Sakura.Duration.Med}">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation Storyboard.TargetName="Knob"
                                                        Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                                        To="{StaticResource Sakura.Color.FgSecondary}"
                                                        Duration="{StaticResource Sakura.Duration.Med}"/>
                                        <ColorAnimation Storyboard.TargetName="Track"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource Sakura.Color.BgSunken}"
                                                        Duration="{StaticResource Sakura.Duration.Med}"/>
                                        <ColorAnimation Storyboard.TargetName="Track"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="{StaticResource Sakura.Color.StrokeSubtle}"
                                                        Duration="{StaticResource Sakura.Duration.Med}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="p:ToggleButton" BasedOn="{StaticResource Sakura.Toggle}"/>

    <Style x:Key="Sakura.ToggleButton" TargetType="p:ToggleButton" BasedOn="{StaticResource Sakura.Toggle}"/>

</ResourceDictionary>
