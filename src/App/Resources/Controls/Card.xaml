<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="Sakura.Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Sakura.Brush.BgRaised}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Sakura.Brush.StrokeSubtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource Sakura.Radius.Card}"/>
        <Setter Property="Padding" Value="{StaticResource Sakura.Pad.Card}"/>
        <Setter Property="Effect" Value="{StaticResource Sakura.Shadow.Card}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <Style x:Key="Sakura.Card.Hoverable" TargetType="Border" BasedOn="{StaticResource Sakura.Card}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Sakura.Brush.AccentPink}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
